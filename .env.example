# Tailnet Media Sync Portal Configuration Template
# Copy this file to '.env' and adjust the variables for your target server environment.

# The Docker image name (e.g. sync-portal:latest or your ghcr.io image)
PORTAL_IMAGE=sync-portal:latest

# The external port you want the portal web interface to listen on.
PORTAL_PORT=8080

# Optional Plex Server Settings (Required only if you want native Plex stream sync)
# PLEX_SERVER_URL=http://your-plex-ip-or-domain:32400
# PLEX_TOKEN=your_plex_token_here

